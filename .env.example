APP_NAME="CRM Ultimate"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=crm_ultimate
DB_USERNAME=crm
DB_PASSWORD=crm

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
POSTGRES_PORT=5433
REDIS_PORT_FORWARD=6380

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=array

JWT_SECRET=change-me-in-production
JWT_TTL_MINUTES=60

# OpenRouter LLM (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
OPENROUTER_TIMEOUT=30

# Emelia (cold outreach) — https://app.emelia.io/settings/api
EMELIA_API_KEY=
EMELIA_WEBHOOK_SECRET= # obligatoire pour sécuriser les webhooks en production
EMELIA_BASE_URL=https://api.emelia.io
EMELIA_TIMEOUT=15

# Tracking d'ouverture des cold emails de Juliette (pixel first-party /o/{token}.gif).
# DOIT être IDENTIQUE au TRACKING_SECRET de la flotte (config/acquisition.env côté Richard).
TRACKING_SECRET=
